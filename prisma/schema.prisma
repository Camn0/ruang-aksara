generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Mengapa: Tabel User membedakan role untuk RBAC.
// Kolom password_hash digunakan khusus untuk NextAuth Credentials provider yang menuntut string tersandi demi keamanan.
model User {
  id            String     @id @default(uuid())
  username      String     @unique
  password_hash String     // Diubah dari password menjadi password_hash sesuai spesifikasi
  role          String     // Hanya berisi 'admin' (God Account), 'author' (Moderator/Penulis), atau 'user' (Reader)
  display_name  String
  avatar_url    String?    // URL foto profil pengguna
  banner_url    String?    // URL foto banner profil pengguna
  bio           String?    @db.Text // Deskripsi diri pengguna
  social_links  Json?      // Tautan sosial (Instagram, Twitter, dll)
  
  // Relasi
  karya_upload   Karya[]    // Karya yang diunggah oleh author/admin
  ratings        Rating[]   
  comments       Comment[]  
  bookmarks      Bookmark[] // Epic 7: Simpan karya (Library)
  reviews        Review[]   // Epic 8: Review formal karya
  review_upvotes ReviewUpvote[]
  review_comments ReviewComment[]
  author_posts   AuthorPost[]
  post_likes     PostLike[]
  post_comments  PostComment[]
  
  // New Epic 12 relations
  reactions     ChapterReaction[]
  comment_votes CommentVote[]
  stats           UserStats?

  // Epic 12: Sistem Follow (Relasi Self-referential Many-to-Many lewat model join explicit)
  followers     Follow[]   @relation("FollowingUser") // Orang-orang yang mengikuti user ini
  following     Follow[]   @relation("FollowerUser")  // Orang-orang yang diikuti oleh user ini
}

// Epic 12: Tabel relasional untuk sistem Follow
model Follow {
  id          String   @id @default(uuid())
  follower_id String   // ID user yang melakukan follow
  follower    User     @relation("FollowerUser", fields: [follower_id], references: [id], onDelete: Cascade)
  
  following_id String  // ID user yang di-follow (Author/Admin)
  following    User    @relation("FollowingUser", fields: [following_id], references: [id], onDelete: Cascade)

  created_at  DateTime @default(now())

  @@unique([follower_id, following_id]) // Tidak boleh follow 2 kali
}

// Epic 6: Categorization
model Genre {
  id    String  @id @default(uuid())
  name  String  @unique
  karya Karya[] // Relasi N:M implisit ke Karya
}

// Mengapa: Entitas Karya menampung judul dan metadata buku.
model Karya {
  id            String     @id @default(uuid())
  title         String
  penulis_alias String     // Statis: Diinput manual author
  uploader_id   String   
  uploader      User       @relation(fields: [uploader_id], references: [id])
  avg_rating    Float      @default(0) // Optimasi fetch
  total_views   Int        @default(0) // Optimasi fetch
  
  // Epic 12: Tambahan Metadata UI Mobile
  cover_url     String?    // URL gambar cover cerita
  deskripsi     String?    @db.Text // Sinopsis cerita
  is_completed  Boolean    @default(false) // Status TAMAT / ONGOING
  
  // Relasi
  bab           Bab[]    
  ratings       Rating[] 
  genres        Genre[]    // Epic 6: Filter Genre
  bookmarks     Bookmark[] // Epic 7: Library
  reviews       Review[]   // Epic 8: Review panjang

  // Indeks untuk Optimasi Query yang sering digunakan (Home, Search, Dashboard)
  @@index([total_views(sort: Desc)])
  @@index([avg_rating(sort: Desc)])
  @@index([uploader_id])
}

// Mengapa: Menyimpan isi cerita. 
model Bab {
  id         String    @id @default(uuid())
  karya_id   String    
  karya      Karya     @relation(fields: [karya_id], references: [id], onDelete: Cascade)
  chapter_no Int       
  title      String?   // Judul bab opsional, fallback ke "Bab N" jika null
  content    String    @db.Text
  created_at DateTime  @default(now())
  comments   Comment[] 
  reactions  ChapterReaction[]
  
  @@unique([karya_id, chapter_no]) // Composite Unique Index
  @@index([karya_id, chapter_no(sort: Asc)]) // Mengurutkan bab berdasarkan chapter_no
}

// Epic 7: Library / Bookmark (Read History)
model Bookmark {
  id           String   @id @default(uuid())
  user_id      String
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  karya_id     String
  karya        Karya    @relation(fields: [karya_id], references: [id], onDelete: Cascade)
  last_chapter Int      @default(1) // Menyimpan posisi bab terakhir dibaca
  updated_at   DateTime @updatedAt
  
  @@unique([user_id, karya_id]) // User hanya bisa mem-bookmark karya 1 kali
  @@index([user_id, updated_at(sort: Desc)]) // Optimasi untuk memuat library pengguna terbaru
}

// Mengapa: Sistem rating bintang (Cepat)
model Rating {
  id       String @id @default(uuid())
  user_id  String 
  user     User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  karya_id String 
  karya    Karya  @relation(fields: [karya_id], references: [id], onDelete: Cascade)
  score    Int    
  
  @@unique([user_id, karya_id]) // Unique Constraint
}

// Epic 8: Review Berformat Teks Panjang (Ditampilkan di halaman depan Karya)
model Review {
  id         String   @id @default(uuid())
  user_id    String 
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  karya_id   String 
  karya      Karya    @relation(fields: [karya_id], references: [id], onDelete: Cascade)
  content    String   @db.Text
  rating     Int?     // Opsi tanpa rating (null) = hanya komentar diskusi
  is_pinned  Boolean? @default(false) // Review yang disematkan oleh author/admin
  created_at DateTime @default(now())
  
  upvotes    ReviewUpvote[]
  comments   ReviewComment[]

  @@unique([user_id, karya_id]) // 1 user = 1 review per karya
}

model ReviewUpvote {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  review_id  String
  review     Review   @relation(fields: [review_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  @@unique([user_id, review_id])
}

model ReviewComment {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  review_id  String
  review     Review   @relation(fields: [review_id], references: [id], onDelete: Cascade)
  content    String   @db.Text
  created_at DateTime @default(now())
}

// Epic 8: Threaded / Nested Comments
model Comment {
  id         String    @id @default(uuid())
  user_id    String   
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  bab_id     String   
  bab        Bab       @relation(fields: [bab_id], references: [id], onDelete: Cascade)
  content    String    @db.Text
  created_at DateTime  @default(now())
  
  parent_id  String?   // Boleh kosong jika ini adalah root comment
  parent     Comment?  @relation("Thread", fields: [parent_id], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("Thread")
  is_pinned  Boolean?  @default(false)
  score      Int       @default(0)
  
  votes      CommentVote[]

  @@index([bab_id, score(sort: Desc), created_at(sort: Desc)])
}

// Epic 12: Comment Voting (Reddit-style)
model CommentVote {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  comment_id String
  comment    Comment  @relation(fields: [comment_id], references: [id], onDelete: Cascade)
  type       Int      // 1 for upvote, -1 for downvote
  created_at DateTime @default(now())

  @@unique([user_id, comment_id])
}

// Epic 12: Independent Chapter Reaction (Emoji-style)
model ChapterReaction {
  id            String   @id @default(uuid())
  user_id       String
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  bab_id        String
  bab           Bab      @relation(fields: [bab_id], references: [id], onDelete: Cascade)
  reaction_type String   // 'LIKE', 'LOVE', 'FIRE', 'WOW', etc.
  created_at    DateTime @default(now())

  @@unique([user_id, bab_id])
}

// Epic 12: Reader Gamification & Stats
model UserStats {
  id                String   @id @default(uuid())
  user_id           String   @unique
  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  total_chapters_read Int    @default(0)
  reading_streak    Int      @default(0)
  last_read_at      DateTime?
  points            Int      @default(0)
}

// Epic 19 & 22: Author Post (Papan Pengumuman Penulis)
model AuthorPost {
  id         String   @id @default(uuid())
  author_id  String
  author     User     @relation(fields: [author_id], references: [id], onDelete: Cascade)
  content    String   @db.Text
  image_url  String?
  created_at DateTime @default(now())

  likes      PostLike[]
  comments   PostComment[]

  @@index([author_id, created_at(sort: Desc)])
}

model PostLike {
  id         String     @id @default(uuid())
  user_id    String
  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post_id    String
  post       AuthorPost @relation(fields: [post_id], references: [id], onDelete: Cascade)
  created_at DateTime   @default(now())

  @@unique([user_id, post_id])
}

model PostComment {
  id         String     @id @default(uuid())
  user_id    String
  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post_id    String
  post       AuthorPost @relation(fields: [post_id], references: [id], onDelete: Cascade)
  content    String     @db.Text
  created_at DateTime   @default(now())
}
